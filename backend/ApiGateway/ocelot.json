{
    "Routes": [
        {
            "UpstreamPathTemplate": "/files",
            "UpstreamHttpMethod": [ "POST" ],
            "DownstreamPathTemplate": "/files",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 7001
                }
            ]
        },
        {
            "UpstreamPathTemplate": "/files/{code}",
            "UpstreamHttpMethod": [ "GET", "DELETE" ],
            "DownstreamPathTemplate": "/files/{code}",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 7001
                }
            ]
        },
        {
            "UpstreamPathTemplate": "/api/objects",
            "UpstreamHttpMethod": [ "POST" ],

            "DownstreamPathTemplate": "/api/objects",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 5282
                }
            ]
        },
        {
            "UpstreamPathTemplate": "/api/objects/{everything}",
            "UpstreamHttpMethod": [ "DELETE" ],

            "DownstreamPathTemplate": "/api/objects/{everything}",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 5282
                }
            ]
        },
        {
            "UpstreamPathTemplate": "/api/objects/signed-url",
            "UpstreamHttpMethod": [ "GET" ],

            "DownstreamPathTemplate": "/api/objects/signed-url",
